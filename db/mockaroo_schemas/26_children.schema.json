      "null_percentage": 0,
      "type": "Blank",
      "formula": "if status=='DISABLED' then \n  if birth_date[0,4]==\"2020\" then concat(Date.strptime(enroll_date, '%Y-%m-%d').year+3,\"-02-25\")\n  else now-years(random(0,1))-days(random(1,100)) end\nelse this end   \n\n"
