      "null_percentage": 0,
      "type": "Datetime",
      "min": "01/01/2020",
      "max": "12/31/2022",
      "format": "%Y-%m-%d",
      "formula": "if month(this) == 2 and day(this) == 29 then\n  if ((child_id - 1) / 20 + 1) % 7 <= 1 then\n    \"2020-02-29\"\n  elsif ((child_id - 1) / 20 + 1) % 7 <= 4 then\n    \"2021-02-28\"\n  else\n    \"2022-02-28\"\n  end\nelse\n  if ((child_id - 1) / 20 + 1) % 7 <= 1 then\n    concat(\"2020-\", pad(month(this).to_s, 2, \"0\", \"left\"), \"-\", pad(day(this).to_s, 2, \"0\", \"left\"))\n  elsif ((child_id - 1) / 20 + 1) % 7 <= 4 then\n    concat(\"2021-\", pad(month(this).to_s, 2, \"0\", \"left\"), \"-\", pad(day(this).to_s, 2, \"0\", \"left\"))\n  else\n    concat(\"2022-\", pad(month(this).to_s, 2, \"0\", \"left\"), \"-\", pad(day(this).to_s, 2, \"0\", \"left\"))\n  end\nend"
    },
    {
